# R Project .gitignore
# ──────────────────────────────────────────────────────────────────────────────
# Only track: shiny_apps/, .github/, get_shinyapps_token.R
# Everything else below is explicitly excluded.

# Exclude all other top-level folders in this Dodona root
Statistiek-in-de-Criminologie/
calculations/
course_content/
data/
outputs/
planning_docs/
PPT and solutions/
Videos/
_archive/
textbook/
Thesis/
images/
writing/

# Exclude Office temp/lock files
~$*
*.tmp

# ──────────────────────────────────────────────────────────────────────────────

# R session artefacts
.Rhistory
.RData
.Rproj.user/
*.Rproj

# Cached/generated data files
*.rds
*.RDS
*.rda
*.RDa
data/
outputs/

# R Markdown / Quarto cache and output folders
*_cache/
*_files/
*.html           # rendered output (not source)
*.pdf            # rendered output (keep if you want to track PDFs)

# rsconnect deployment manifests (regenerated on each deploy)
rsconnect/

# Secrets and credentials — NEVER commit these
.secrets
.Renviron
.env
*.env

# OS artefacts
.DS_Store
Thumbs.db

# Large binary files unlikely to need version control
*.png
*.jpg
*.jpeg
*.gif
*.svg

# Exceptions: keep R scripts and markdown in media/ folders
!**/media/*.R
!**/media/*.md

# Python/Shiny generated artefacts
shiny_apps/**/.venv/
shiny_apps/**/__pycache__/
shiny_apps/**/rsconnect-python/
shiny_apps/**/*.pyc
shiny_apps/**/*.pyo
shiny_apps/**/*.log
.positai
